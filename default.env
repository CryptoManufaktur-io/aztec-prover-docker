# Do not update default.env directly - copy it to .env and nano .env
# Which components to run: validator/sequencer and optional monitor sidecars
COMPOSE_FILE=validator.yml

AZTEC_REPO=aztecprotocol/aztec
AZTEC_TAG=latest
# Whether an external watchtower should automatically pull new versions of the above tag when available
# Requires a watchtower service running on the host.
AZTEC_AUTOUPDATE=false

# Parameters for validator/sequencer
NETWORK=testnet
# Execution Layer RPC, comma-separated
L1_RPC=https://el-node-rpc.example.com,https://el-node2-rpc.example.com
# Consensus Layer REST
L1_REST=https://cl-node-rest.example.com
# The public IP address of your node
PUBLIC_IP_ADDRESS=
# Blob sink URL
BLOB_SINK_URL=
# Where to send metrics. No effect if left empty
# E.g. http://otel-collector:4318/v1/metrics
OTEL_METRICS_ENDPOINT=

# Parameters when running a sequencer/validator
# Private key of an L1 wallet, for gas. For a sequencer, this will be used to pay gas for all validators
L1_WALLET_PRIVATE_KEY=

# Parameters when running a sequencer/validator
# Public address of an Ethereum wallet
COINBASE=
# Private key(s) of L1 wallets, comma-separated, one for each sequencer/validator
VALIDATOR_PRIVATE_KEYS=
# P2P port the validator uses, host-mapped and Internet-reachable
VALIDATOR_P2P_PORT=40400
# Additional command line parameters to pass to the sequencer
SEQUENCER_EXTRAS=
# Governance payload, if a vote is active
GOVERNANCE_PROPOSER_PAYLOAD_ADDRESS=

# External Docker network if using ext-network.yml
DOCKER_EXT_NETWORK=traefik_default

# info, warn, error, trace
LOG_LEVEL=info

# Coinbase Monitor - monitors delegations and updates coinbase addresses
# Your provider ID on the Staking Dashboard
PROVIDER_ID=
# Staking Dashboard API URL
STAKING_API_URL=
# How often to poll for new delegations (seconds)
MONITOR_POLL_INTERVAL=300
# Slack webhook URL for notifications (optional)
SLACK_WEBHOOK_URL=

# Provider Key Monitor - read-only Prometheus exporter for provider queue length
# Network contract defaults to use for provider key monitoring
PROVIDER_KEY_MONITOR_NETWORK=mainnet
# Optional queue contract override. Leave empty to use the network default.
PROVIDER_QUEUE_CONTRACT_ADDRESS=
# How often to poll provider queue length (seconds)
PROVIDER_KEY_MONITOR_POLL_INTERVAL=300
# Provider key monitor Prometheus metrics port
PROVIDER_KEY_MONITOR_METRICS_PORT=9102

# Slash Monitor - monitors on-chain slashing proposals targeting our validators
# Network contract defaults to use for slashing monitoring
SLASH_MONITOR_NETWORK=mainnet
# How often to poll L1 for slashing state (seconds)
SLASH_MONITOR_POLL_INTERVAL=900
# Slash monitor Prometheus metrics port
SLASH_MONITOR_METRICS_PORT=9101

# You can pin the version of aztec-prover-docker here
SCRIPT_TAG=

# Used by aztecd update - please do not adjust
ENV_VERSION=8
